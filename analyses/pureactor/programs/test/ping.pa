(letrec
  ((ping (behavior (state)
    (ping (ref)
      (begin 
        (send ref pong self)
        (become ping 0)))
    (pang (ref)
      (become ping 1))))
   (pong (behavior (state)
     (pong (ref)
        (begin
          (send ref ping self)
          (become pong 0))))))
  (letrec
    ((ping-actor (spawn ping 0))
     (pong-actor (spawn pong 0)))
    (begin
      (send ping-actor ping pong-actor)
      (send ping-actor pang nil))))
